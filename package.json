{
  "name": "refractive",
  "version": "0.0.5",
  "description": "React HOC for liquid-glass refractive effects using SVG backdrop filters, with native Chromium and cross-browser fallbacks",
  "keywords": [
    "react",
    "hoc",
    "glass",
    "liquid-glass",
    "refractive",
    "backdrop-filter",
    "svg-filter",
    "displacement-map",
    "frosted",
    "specular"
  ],
  "license": "MIT",
  "homepage": "https://salnika.github.io/refractive/",
  "bugs": {
    "url": "https://github.com/Salnika/refractive/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Salnika/refractive"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "CHANGELOG.md",
    "dist",
    "LICENSE",
    "LICENSE-APACHE.md",
    "LICENSE-MIT.md",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vp build",
    "dev": "storybook dev -p 6006",
    "dev:lib": "vp build --watch",
    "lint:eslint": "vp lint --type-aware --report-unused-disable-directives-severity=error .",
    "fix:eslint": "vp lint --fix --type-aware --report-unused-disable-directives-severity=error .",
    "lint:tsc": "tsgo --noEmit",
    "prepublishOnly": "vp build",
    "build-storybook": "storybook build",
    "prepare": "vp config"
  },
  "dependencies": {
    "@html2canvas/html2canvas": "^1.6.3"
  },
  "devDependencies": {
    "@github-ui/storybook-addon-performance-panel": "^1.1.4",
    "@rolldown/plugin-babel": "0.2.1",
    "@storybook/react-vite": "10.2.19",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260315.1",
    "@vitejs/plugin-react": "6.0.1",
    "babel-plugin-react-compiler": "1.0.0",
    "rolldown-plugin-dts": "0.22.5",
    "storybook": "10.2.19",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "packageManager": "pnpm@10.33.2"
}
